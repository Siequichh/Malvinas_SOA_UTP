# ==============================================================
# malvinas-eureka-server - Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ==============================================================

# Environment (dev | staging | prod)
ENVIRONMENT=

# Server
SERVER_PORT=8761

# Hostname
# Local:  localhost
# Render: nombre-del-servicio-eureka.onrender.com
EUREKA_HOSTNAME=
