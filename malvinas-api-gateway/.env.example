# ==============================================================
# malvinas-api-gateway - Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ==============================================================

# Active Spring profile: dev | prod
ENVIRONMENT=dev

# Server
SERVER_PORT=8080

# JWT — must match auth-service and personal-service
JWT_SECRET=

# Eureka base URL (WITHOUT trailing /eureka)
# Dev:  http://localhost:8761
# Prod: https://<your-eureka-service>.onrender.com
EUREKA_URI=http://localhost:8761

# ----------------------------------------------------------
# Route URIs (optional — only needed to override defaults)
# In prod these are set automatically via application-prod.yml
# using lb:// Eureka discovery. Override here only if needed.
# ----------------------------------------------------------
# ROUTES_AUTH_URI=lb://auth-service
# ROUTES_PERSONAL_URI=lb://personal-service
# ROUTES_VEHICULOS_URI=lb://vehiculos-service
# ROUTES_CARGAS_URI=lb://cargas-service
# ROUTES_RUTAS_URI=lb://rutas-service
# ROUTES_REPORTES_URI=lb://reportes-service
