# ==============================================================
# malvinas-rutas-service - Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# ==============================================================

# Active Spring profile: dev | prod
ENVIRONMENT=dev

# Server
SERVER_PORT=8084

# ----------------------------------------------------------
# Database - DEV  (application-dev.yml → LOCAL_DB_*)
# ----------------------------------------------------------
LOCAL_DB_HOST=localhost
LOCAL_DB_NAME=malvinas_db
LOCAL_DB_USERNAME=postgres
LOCAL_DB_PASSWORD=postgres

# ----------------------------------------------------------
# Database - PROD (application-prod.yml → POSTGRESQL_*)
# Get these from Render → PostgreSQL → Connection details
# ----------------------------------------------------------
POSTGRESQL_HOST=
POSTGRESQL_DB=
POSTGRESQL_USER=
POSTGRESQL_PASS=

# Eureka base URL (WITHOUT trailing /eureka)
# Dev:  http://localhost:8761
# Prod: https://<your-eureka-service>.onrender.com
EUREKA_URI=http://localhost:8761
